generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── SaaS ────────────────────────────────────────────────────────────────────

model Tenant {
  id               String     @id @default(cuid())
  slug             String     @unique
  name             String
  logoUrl          String?
  primaryColor     String     @default("#f97316")
  customDomain     String?    @unique
  plan             TenantPlan @default(FREE)
  stripeCustomerId String?
  stripeSubId      String?
  active           Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  units    TenantUnit[]
  services TenantService[]
}

model TenantUnit {
  id        String   @id @default(cuid())
  tenantId  String
  unitKey   String   // matches existing unitId strings ("caucaia", "pecem", etc.)
  name      String
  city      String?
  address   String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, unitKey])
  @@index([tenantId])
}

model TenantService {
  id          String  @id @default(cuid())
  tenantId    String
  serviceType String  // "grooming" | "vet" | "adoption" | "blog" | "delivery"
  enabled     Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, serviceType])
  @@index([tenantId])
}

enum TenantPlan {
  FREE
  PRO
  ENTERPRISE
}

// ─── Core ────────────────────────────────────────────────────────────────────

model Appointment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String?

  serviceType String // "grooming" | "vet"

  package String? // "banho" | "banho-tosa" | "spa"
  addons  String[]

  unitId       String
  professional String?

  petName  String
  petBreed String?
  petSize  String? // "small" | "medium" | "large"

  tutorName String
  tutorCpf  String?
  phone     String
  email     String?

  appointmentDate DateTime
  appointmentTime String

  paymentId     String? // ID da preferência Mercado Pago
  paymentStatus PaymentStatus @default(PENDING)
  totalPrice    Decimal       @db.Decimal(10, 2)

  status AppointmentStatus @default(AWAITING_PAYMENT)

  notes String?
  isVip Boolean @default(false)

  @@index([tenantId])
  @@index([unitId])
  @@index([status])
  @@index([appointmentDate])
  @@index([paymentStatus])
}

enum AppointmentStatus {
  AWAITING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String
  role      UserRole @default(RECEPTIONIST)
  unitId    String?
  tenantId  String?
  email     String?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

enum UserRole {
  ADMIN
  RECEPTIONIST
}

model AdoptionPet {
  id          String   @id @default(cuid())
  name        String
  species     String // "cachorro" | "gato"
  breed       String?
  age         String?
  gender      String // "macho" | "femea"
  size        String? // "pequeno" | "medio" | "grande"
  description String?
  imageUrl    String?
  available   Boolean  @default(true)
  status      String   @default("disponivel")
  unitId      String?
  tenantId    String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

model BlogPost {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  tag        String
  excerpt    String
  content    String
  coverColor String   @default("orange")
  imageUrl   String?
  readTime   String   @default("5 min")
  published  Boolean  @default(false)
  tenantId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([published])
  @@index([tenantId])
}

model Professional {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  unitId    String
  tenantId  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([unitId])
  @@index([tenantId])
}

model Availability {
  id           String   @id @default(cuid())
  professional String
  unitId       String
  tenantId     String?
  date         DateTime @db.Date
  slots        String[]

  @@unique([professional, date])
  @@index([unitId])
  @@index([date])
  @@index([tenantId])
}

// ─── Clínica Veterinária ──────────────────────────────────────────────────────

model Client {
  id         String   @id @default(cuid())
  tenantId   String?
  name       String
  cpf        String?
  phone      String
  email      String?
  address    String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pets Pet[]

  @@index([tenantId])
  @@index([phone])
}

model Pet {
  id        String   @id @default(cuid())
  tenantId  String?
  clientId  String
  name      String
  species   String   // "cao" | "gato" | "outro"
  breed     String?
  color     String?
  birthDate DateTime?
  gender    String?  // "macho" | "femea"
  weight    Decimal? @db.Decimal(6, 2)
  microchip String?
  notes     String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  records MedicalRecord[]

  @@index([clientId])
  @@index([tenantId])
}

model MedicalRecord {
  id          String   @id @default(cuid())
  tenantId    String?
  petId       String
  vetName     String?
  unitId      String?
  date        DateTime @default(now())

  // SOAP
  subjetivo   String?  @db.Text
  objetivo    String?  @db.Text
  avaliacao   String?  @db.Text
  plano       String?  @db.Text

  // Sinais vitais (JSON: { temperatura, frequenciaCardiaca, frequenciaRespiratoria, peso, tpc })
  sinaisVitais         Json?

  // IA
  transcript  String?  @db.Text
  aiSummary   String?  @db.Text
  aiDiagnoses String[]
  aiMeds      String[]
  aiExams     String[]
  aiRetorno   String?

  // Prescrições e exames
  prescriptions Prescription[]
  examOrders    ExamOrder[]

  status      String   @default("open") // "open" | "signed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([tenantId])
  @@index([date])
}

model Prescription {
  id              String        @id @default(cuid())
  medicalRecordId String
  medication      String
  dose            String?
  frequency       String?
  duration        String?
  instructions    String?
  createdAt       DateTime      @default(now())

  record MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
}

model ExamOrder {
  id              String        @id @default(cuid())
  medicalRecordId String
  examName        String
  notes           String?
  result          String?       @db.Text
  status          String        @default("pending") // "pending" | "done"
  createdAt       DateTime      @default(now())

  record MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
}

// ─── PDV ─────────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  tenantId    String?
  unitId      String?
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  costPrice   Decimal? @db.Decimal(10, 2)
  category    String   @default("produto") // "produto" | "medicamento" | "alimento" | "acessorio" | "servico"
  barcode     String?
  stock       Int      @default(0)
  trackStock  Boolean  @default(true)
  active      Boolean  @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  saleItems SaleItem[]

  @@index([tenantId])
  @@index([unitId])
  @@index([category])
}

model Sale {
  id            String     @id @default(cuid())
  tenantId      String?
  unitId        String
  sellerId      String?
  sellerName    String?
  clientName    String?
  clientPhone   String?
  clientId      String?

  subtotal      Decimal    @db.Decimal(10, 2)
  discount      Decimal    @default(0) @db.Decimal(10, 2)
  total         Decimal    @db.Decimal(10, 2)

  paymentMethod String     // "cash" | "card_credit" | "card_debit" | "pix"
  amountPaid    Decimal?   @db.Decimal(10, 2)
  change        Decimal?   @db.Decimal(10, 2)

  status        String     @default("completed") // "completed" | "cancelled"
  notes         String?

  items         SaleItem[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([tenantId])
  @@index([unitId])
  @@index([sellerId])
  @@index([createdAt])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  productId String?
  name      String
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int
  subtotal  Decimal  @db.Decimal(10, 2)

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

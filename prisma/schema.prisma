generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id              String            @id @default(cuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  serviceType     String            // "grooming" | "vet"

  package         String?           // "banho" | "banho-tosa" | "spa"
  addons          String[]

  unitId          String
  professional    String?

  petName         String
  petBreed        String?
  petSize         String?           // "small" | "medium" | "large"

  tutorName       String
  phone           String
  email           String?

  appointmentDate DateTime
  appointmentTime String

  paymentId       String?           // ID da preferência Mercado Pago
  paymentStatus   PaymentStatus     @default(PENDING)
  totalPrice      Decimal           @db.Decimal(10, 2)

  status          AppointmentStatus @default(AWAITING_PAYMENT)

  notes           String?
  isVip           Boolean           @default(false)

  @@index([unitId])
  @@index([status])
  @@index([appointmentDate])
  @@index([paymentStatus])
}

enum AppointmentStatus {
  AWAITING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String
  role      UserRole @default(RECEPTIONIST)
  unitId    String?
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  RECEPTIONIST
}

model AdoptionPet {
  id          String   @id @default(cuid())
  name        String
  species     String   // "cachorro" | "gato"
  breed       String?
  age         String?
  gender      String   // "macho" | "femea"
  size        String?  // "pequeno" | "medio" | "grande"
  description String?
  imageUrl    String?
  available   Boolean  @default(true)
  status      String   @default("disponivel")
  unitId      String?
  createdAt   DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  tag         String
  excerpt     String
  content     String
  coverColor  String   @default("orange")
  imageUrl    String?
  readTime    String   @default("5 min")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
}

model Availability {
  id           String   @id @default(cuid())
  professional String
  unitId       String
  date         DateTime @db.Date
  slots        String[]

  @@unique([professional, date])
  @@index([unitId])
  @@index([date])
}
